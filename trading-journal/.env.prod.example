# ─── BASE DE DATOS ───────────────────────────────────────────────────────────
# Credenciales del usuario exclusivo de tradelog en el postgres compartido
# El host y puerto los fija el docker-compose, no hace falta declararlos aquí
DB_NAME=tradelog
DB_USER=tradelog_user
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO

# ─── AUTENTICACIÓN ───────────────────────────────────────────────────────────
JWT_SECRET=CAMBIAR_POR_STRING_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://tradelog.nesx.co
ALLOWED_ORIGINS=https://tradelog.nesx.co

# ─── VOLÚMENES EN EL HOST ────────────────────────────────────────────────────
# Rutas en la VPS donde se guardan uploads e imágenes (solo las lee docker-compose)
HOST_UPLOADS_DIR=/home/deploy/tradelog-data/uploads
HOST_LOGS_DIR=/home/deploy/tradelog-data/logs
